# 이 파일을 `.env` 로 복사한 뒤 실제 값을 채워 넣으세요.
#   cp .env.example .env
# `.env` 는 git 에 커밋되지 않습니다 (.gitignore 참고).

# --- LLM (ChatOpenAI) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5-nano

# --- Gmail MCP 서버 (Streamable HTTP) ---
GMAIL_MCP_SERVER_URL=http://localhost:8000/mcp

# --- 상태 지속성 (PostgresSaver, 프로덕션) ---
# 개발 환경(InMemorySaver)에서는 비워 두어도 됩니다.
# DATABASE_URL=postgresql://user:password@localhost:5432/gmail_agent
