# 이 파일을 `.env` 로 복사한 뒤 실제 값을 채워 넣으세요.
#   cp .env.example .env
# `.env` 는 git 에 커밋되지 않습니다 (.gitignore 참고).

# --- LLM (ChatOpenAI) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5-nano

# --- Gmail MCP 서버 (shinzo-labs/gmail-mcp) ---
# 전송 방식: stdio(로컬 개발, 앱이 npx 로 서버를 자식 프로세스로 실행)
#          | streamable_http(원격/프로덕션, 별도 기동된 서버에 HTTP 연결)
GMAIL_MCP_TRANSPORT=stdio
# streamable_http 일 때만 필요. stdio 에서는 비워 둡니다.
# GMAIL_MCP_SERVER_URL=http://localhost:3000/mcp
# 버전 고정(서드파티 스키마 변경 리스크 대응). 특별한 이유가 없으면 그대로 둡니다.
GMAIL_MCP_PACKAGE=@shinzolabs/gmail-mcp@1.7.4

# --- Gmail OAuth 자격증명 (MCP 서버에 주입) ---
# 로컬 개발: 아래를 비워 두면 Step 2 산출물인 token.json 에서 자동 추출합니다.
# 프로덕션/ECS: 아래 3개를 Secrets 로 명시 주입하는 것을 권장합니다(토큰 파일 미배포).
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REFRESH_TOKEN=
GMAIL_TOKEN_PATH=token.json

# --- 상태 지속성 (PostgresSaver) ---
DATABASE_URL=postgresql://<user>:<password>@<host>:<port>/<database>
